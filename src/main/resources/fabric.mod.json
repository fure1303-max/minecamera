{
  "schemaVersion": 1,
  "id": "minecamera",
  "version": "${version}",
  "name": "MineCamera",
  "description": "A Fabric camera mod for Minecraft Java 1.21.11 with handheld and tripod photography.",
  "icon": "assets/minecamera/icon.png",
  "authors": [
    "fure1303-max"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.minecamera.MineCameraMod"
    ],
    "client": [
      "com.minecamera.client.MineCameraClient"
    ]
  },
  "mixins": [
    "minecamera.client.mixins.json"
  ],
  "depends": {
    "fabricloader": "0.19.3",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
